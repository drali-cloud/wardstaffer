generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id            String @id
  name          String
  gender        String
  previousWards Json
}

model Ward {
  id           String @id
  name         String
  requirements Json
}

model Assignment {
  id        String @id
  date      String
  wardId    String
  doctorIds Json
}
